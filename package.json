{
  "name": "sistema-certificado-digital",
  "version": "2.0.0",
  "description": "Sistema completo para venda de certificados digitais e-CPF e e-CNPJ com integração Safeweb, Assertiva e Safe2Pay",
  "main": "scripts/iniciar-sistema.js",
  "scripts": {
    "start": "./iniciar-sistema.sh",
    "stop": "./parar-sistema.sh",
    "validate": "node scripts/validar-configuracao.js",
    "test:ecpf": "node testes/teste-ecpf-caepf-cei.js",
    "test:ecnpj": "node testes/teste-ecnpj-cei.js",
    "test:completo": "node testes/teste-fluxo-completo-protocolo-boleto.js",
    "test:all": "npm run test:ecpf && npm run test:ecnpj && npm run test:completo",
    "assertiva": "cd api-assertiva && node assertiva-proxy.js",
    "safeweb": "cd api-safeweb && node safeweb-proxy.js",
    "logs:assertiva": "tail -f logs/API-Assertiva.log",
    "logs:safeweb": "tail -f logs/API-Safeweb.log",
    "setup": "cp .env.example .env && echo 'Configure o arquivo .env com suas credenciais'",
    "start:assertiva": "node src/backend/proxies/assertiva-proxy.js",
    "start:safeweb": "node src/backend/proxies/safeweb-proxy.js",
    "start:all": "npm-run-all --parallel start:assertiva start:safeweb",
    "check:env": "node scripts/validar-configuracao.js",
    "run:config": "node scripts/executar-com-config.js",
    "run:ecnpj:pix": "node scripts/gerar-ecnpj-com-pix.js",
    "test": "node tests/teste-fluxo-completo-protocolo-boleto.js",
    "start:api": "node src/backend/server.js",
    "start:clean": "node src/main/server.js",
    "dev:clean": "nodemon src/main/server.js",
    "test:smoke:clean": "node tests/smoke-clean.js"
  },
  "keywords": [
    "certificado-digital",
    "checkout",
    "assertiva",
    "safeweb",
    "api-integration",
    "javascript",
    "frontend"
  ],
  "author": "Projeto Certificado Campinas",
  "license": "MIT",
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "cssnano": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "postcss": "^8.5.6",
    "prettier": "^2.8.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "http-server": "^14.0.0",
    "jsonwebtoken": "^9.0.2",
    "live-server": "^1.2.2",
    "moment": "^2.30.1",
    "mysql2": "^3.14.4",
    "nodemailer": "^7.0.6",
    "nodemon": "^3.1.10",
    "nunjucks": "^3.2.4",
    "postcss-cli": "^11.0.1",
    "safe2pay": "^1.1.12",
    "uuid": "^12.0.0",
    "validator": "^13.15.15",
    "zod": "^3.23.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/projeto-certificado-campinas/site_certificado_online.git"
  },
  "bugs": {
    "url": "https://github.com/projeto-certificado-campinas/site_certificado_online/issues"
  },
  "homepage": "https://github.com/projeto-certificado-campinas/site_certificado_online#readme"
}